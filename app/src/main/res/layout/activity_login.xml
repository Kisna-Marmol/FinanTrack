<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_fondo"
    android:fillViewport="true"
    tools:context=".Login">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="32dp">

        <!-- ─── LOGO ─────────────────────────────────────────────────────────── -->

        <ImageView
            android:id="@+id/img_logo"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.498"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/icono_app_sin_fondo" />

            <!-- ─── TÍTULO ────────────────────────────────────────────────────────── -->

        <TextView
            android:id="@+id/tbl_titulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="FinanTrack"
            android:textColor="@color/texto_principal"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/img_logo" />

        <!-- ─── SUBTÍTULO ─────────────────────────────────────────────────────── -->
        <TextView
            android:id="@+id/tbl_subtitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Gestiona tus finanzas de manera inteligente"
            android:textColor="@color/texto_secundario"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tbl_titulo" />

        <!-- ─── CARD PRINCIPAL ───────────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_inicio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tbl_subtitulo"
            app:layout_constraintVertical_bias="0.0">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- ── TABS: Iniciar Sesión / Registrarse ──────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_rounded"
                    android:orientation="horizontal"
                    android:padding="4dp">

                    <Button
                        android:id="@+id/btnLogin"
                        style="@style/Widget.AppCompat.Button.Borderless"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_activo"
                        app:backgroundTint="@null"
                        android:text="Iniciar Sesión"
                        android:textColor="@android:color/white"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnRegister"
                        style="@style/Widget.AppCompat.Button.Borderless"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_inactivo"
                        app:backgroundTint="@null"
                        android:text="Registrarse"
                        android:textColor="@color/texto_secundario"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- ══════════════════════════════════════════════════════════ -->
                <!-- PANEL LOGIN                                                -->
                <!-- ══════════════════════════════════════════════════════════ -->
                <LinearLayout
                    android:id="@+id/panel_login"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <!-- Label Correo -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Correo electrónico"
                        android:textColor="@color/texto_principal"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <!-- Campo Correo -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/email"
                            app:tint="@color/texto_secundario" />

                        <EditText
                            android:id="@+id/et_email"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="tu@email.com"
                            android:inputType="textEmailAddress"
                            android:textColor="@color/texto_principal"
                            android:textColorHint="@color/texto_secundario"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Label Contraseña -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="6dp"
                        android:text="Contraseña"
                        android:textColor="@color/texto_principal"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <!-- Campo Contraseña -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_lock"
                            app:tint="@color/texto_secundario" />

                        <EditText
                            android:id="@+id/et_password"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="••••••••"
                            android:inputType="textPassword"
                            android:textColor="@color/texto_principal"
                            android:textColorHint="@color/texto_secundario"
                            android:textSize="14sp" />

                        <ImageView
                            android:id="@+id/iv_toggle_password"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_eye"
                            android:clickable="true"
                            android:focusable="true"
                            app:tint="@color/texto_secundario" />
                    </LinearLayout>

                    <!-- Recordarme + Olvidaste -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <CheckBox
                            android:id="@+id/cb_recordarme"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/color_primario"
                            android:text="Recordarme"
                            android:textColor="@color/texto_secundario"
                            android:textSize="12sp" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/tv_olvide_password"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="¿Olvidaste tu contraseña?"
                            android:textColor="@color/color_secundario"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>

                    <!-- Botón Iniciar Sesión -->
                    <Button
                        android:id="@+id/btn_iniciar_sesion"
                        style="@style/Widget.AppCompat.Button.Borderless"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/bg_button_activo"
                        app:backgroundTint="@null"
                        android:text="Iniciar Sesión"
                        android:textColor="@android:color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <!-- Divider: O continúa con -->

                    <!-- Botones sociales -->

                </LinearLayout>
                <!-- FIN PANEL LOGIN -->

                <!-- ══════════════════════════════════════════════════════════ -->
                <!-- PANEL REGISTRO                                             -->
                <!-- ══════════════════════════════════════════════════════════ -->
                <LinearLayout
                    android:id="@+id/panel_registro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <!-- Label Nombre -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Nombre completo"
                        android:textColor="@color/texto_principal"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <!-- Campo Nombre -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_person"
                            app:tint="@color/texto_secundario" />

                        <EditText
                            android:id="@+id/et_nombre"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="Tu nombre completo"
                            android:inputType="textPersonName"
                            android:textColor="@color/texto_principal"
                            android:textColorHint="@color/texto_secundario"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Label Correo -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="6dp"
                        android:text="Correo electrónico"
                        android:textColor="@color/texto_principal"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <!-- Campo Correo Registro -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/email"
                            app:tint="@color/texto_secundario" />

                        <EditText
                            android:id="@+id/et_email_registro"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="tu@email.com"
                            android:inputType="textEmailAddress"
                            android:textColor="@color/texto_principal"
                            android:textColorHint="@color/texto_secundario"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Label Contraseña Registro -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="6dp"
                        android:text="Contraseña"
                        android:textColor="@color/texto_principal"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <!-- Campo Contraseña Registro -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_lock"
                            app:tint="@color/texto_secundario" />

                        <EditText
                            android:id="@+id/et_password_registro"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="••••••••"
                            android:inputType="textPassword"
                            android:textColor="@color/texto_principal"
                            android:textColorHint="@color/texto_secundario"
                            android:textSize="14sp" />

                        <ImageView
                            android:id="@+id/iv_toggle_pwd_reg"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_eye"
                            android:clickable="true"
                            android:focusable="true"
                            app:tint="@color/texto_secundario" />
                    </LinearLayout>

                    <!-- Label Confirmar Contraseña -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="6dp"
                        android:text="Confirmar contraseña"
                        android:textColor="@color/texto_principal"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <!-- Campo Confirmar Contraseña -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_lock"
                            app:tint="@color/texto_secundario" />

                        <EditText
                            android:id="@+id/et_confirmar_password"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="••••••••"
                            android:inputType="textPassword"
                            android:textColor="@color/texto_principal"
                            android:textColorHint="@color/texto_secundario"
                            android:textSize="14sp" />

                        <ImageView
                            android:id="@+id/iv_toggle_pwd_confirm"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_eye"
                            android:clickable="true"
                            android:focusable="true"
                            app:tint="@color/texto_secundario" />
                    </LinearLayout>

                    <!-- Botón Crear Cuenta -->
                    <Button
                        android:id="@+id/btn_crear_cuenta"
                        style="@style/Widget.AppCompat.Button.Borderless"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/bg_button_activo"
                        app:backgroundTint="@null"
                        android:text="Crear Cuenta"
                        android:textColor="@android:color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <!-- ¿Ya tienes cuenta? -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="¿Ya tienes cuenta? "
                            android:textColor="@color/texto_secundario"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tv_ir_login"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Inicia sesión"
                            android:textColor="@color/color_primario"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>

                </LinearLayout>
                <!-- FIN PANEL REGISTRO -->

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>